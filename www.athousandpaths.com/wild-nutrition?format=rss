                <img data-stretch="false" data-image="https://images.squarespace-cdn.com/content/v1/55762892e4b08f79780d92e7/1603323326103-DIO3QZKXF7PKBLVJVX9K/101%25+potassium+graph" data-image-dimensions="313x251" data-image-focal-point="0.5,0.5" alt="" data-load="false" elementtiming="system-image-block" data-sqsp-image-classic-block-image src="https://images.squarespace-cdn.com/content/v1/55762892e4b08f79780d92e7/1603323326103-DIO3QZKXF7PKBLVJVX9K/101%25+potassium+graph?format=1000w" width="313" height="251" sizes="(max-width: 640px) 100vw, (max-width: 767px) 100vw, 100vw" onload="this.classList.add(&quot;loaded&quot;)" srcset="https://images.squarespace-cdn.com/content/v1/55762892e4b08f79780d92e7/1603323326103-DIO3QZKXF7PKBLVJVX9K/101%25+potassium+graph?format=100w 100w, https://images.squarespace-cdn.com/content/v1/55762892e4b08f79780d92e7/1603323326103-DIO3QZKXF7PKBLVJVX9K/101%25+potassium+graph?format=300w 300w, https://images.squarespace-cdn.com/content/v1/55762892e4b08f79780d92e7/1603323326103-DIO3QZKXF7PKBLVJVX9K/101%25+potassium+graph?format=500w 500w, https://images.squarespace-cdn.com/content/v1/55762892e4b08f79780d92e7/1603323326103-DIO3QZKXF7PKBLVJVX9K/101%25+potassium+graph?format=750w 750w, https://images.squarespace-cdn.com/content/v1/55762892e4b08f79780d92e7/1603323326103-DIO3QZKXF7PKBLVJVX9K/101%25+potassium+graph?format=1000w 1000w, https://images.squarespace-cdn.com/content/v1/55762892e4b08f79780d92e7/1603323326103-DIO3QZKXF7PKBLVJVX9K/101%25+potassium+graph?format=1500w 1500w, https://images.squarespace-cdn.com/content/v1/55762892e4b08f79780d92e7/1603323326103-DIO3QZKXF7PKBLVJVX9K/101%25+potassium+graph?format=2500w 2500w" loading="lazy" decoding="async" data-loader="sqs">

            
          
        
          
        

        
      
